# ==============================================
# WALLET CONFIGURATION (REQUIRED)
# ==============================================
# Your EOA private key (from MetaMask or similar wallet)
# Must have USDC.e on Polygon and small amount of POL for gas
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ==============================================
# TARGET WALLET(S) TO COPY (REQUIRED if AUTO_DISCOVER disabled)
# ==============================================
# Comma-separated list of Polymarket wallet addresses to copy-trade
# Find top traders via https://polymarket.com/leaderboard
# Leave empty if using AUTO_DISCOVER_WALLETS
TARGET_WALLETS=

# ==============================================
# RPC CONFIGURATION
# ==============================================
# Dedicated Polygon RPC endpoint (QuickNode, Alchemy, or Chainstack)
# Free-tier public nodes WILL fail under load — use a paid endpoint
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ==============================================
# POSITION SIZING
# ==============================================
# Multiplier relative to the target trader's position size (0.1 = 10%)
POSITION_MULTIPLIER=0.1

# Maximum single trade size in USDC
MAX_TRADE_SIZE=100

# Minimum trade size in USDC (trades below this are skipped)
MIN_TRADE_SIZE=1

# ==============================================
# ORDER CONFIGURATION
# ==============================================
# Order type: FOK (Fill-Or-Kill) recommended for copy-trading
# Options: FOK, GTC, FAK
ORDER_TYPE=FOK

# Slippage tolerance (0.02 = 2%)
SLIPPAGE_TOLERANCE=0.02

# ==============================================
# RISK MANAGEMENT
# ==============================================
# Maximum total notional for the session (0 = unlimited)
MAX_SESSION_NOTIONAL=1000

# Maximum notional per individual market (0 = unlimited)
MAX_PER_MARKET_NOTIONAL=200

# Daily loss limit as fraction of capital (0.05 = 5%)
DAILY_LOSS_LIMIT=0.05

# Maximum drawdown from peak capital (0.25 = 25%)
MAX_DRAWDOWN=0.25

# Total loss limit — permanent halt (0.40 = 40%)
TOTAL_LOSS_LIMIT=0.40

# ==============================================
# MONITORING
# ==============================================
# Enable WebSocket for real-time monitoring (faster than polling)
USE_WEBSOCKET=true

# REST polling interval in milliseconds (used as fallback)
POLL_INTERVAL=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ==============================================
# AUTO-DISCOVER TOP TRADERS (Optional)
# ==============================================
# Automatically discover top Polymarket traders at startup
# by querying the leaderboard API — no need to manually find wallets
AUTO_DISCOVER_WALLETS=true

# Time period for leaderboard ranking: DAY, WEEK, MONTH, ALL
LEADERBOARD_TIME_PERIOD=WEEK

# Market category: OVERALL, POLITICS, CRYPTO, SPORTS, SCIENCE
LEADERBOARD_CATEGORY=OVERALL

# How to rank traders: PNL, VOLUME, WIN_RATE
LEADERBOARD_ORDER_BY=PNL

# Number of traders to fetch from leaderboard API
LEADERBOARD_FETCH_LIMIT=50

# Minimum P&L in USD to qualify as a top trader
LEADERBOARD_MIN_PNL=500

# Minimum win rate (0.6 = 60%)
LEADERBOARD_MIN_WIN_RATE=0.6

# Minimum number of trades to qualify
LEADERBOARD_MIN_TRADES=20

# Maximum number of wallets to copy-trade (top N)
LEADERBOARD_MAX_WALLETS=5

# How often to refresh the leaderboard (minutes)
LEADERBOARD_REFRESH_MINUTES=60

# ==============================================
# AI TRADE FILTER (Optional)
# ==============================================
# Enable AI-powered probability estimation before copying trades
# The bot will call an LLM to estimate true probability and only
# copy trades where AI consensus aligns with the target's direction
AI_FILTER_ENABLED=false

# LLM provider: openai | anthropic | openrouter | custom
AI_FILTER_PROVIDER=openai

# API key for the LLM provider
AI_FILTER_API_KEY=sk-YOUR_KEY_HERE

# Primary model (used for probability estimation)
# OpenAI: gpt-4o, gpt-4o-mini
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-20250514
# OpenRouter: anthropic/claude-sonnet-4-20250514, openai/gpt-4o
# Custom: any model name your provider accepts
AI_FILTER_MODEL=gpt-4o

# Custom provider base URL (required when AI_FILTER_PROVIDER=custom)
# Examples:
#   Ollama:     http://localhost:11434/v1
#   LM Studio:  http://localhost:1234/v1
#   vLLM:       http://localhost:8000/v1
#   LiteLLM:    http://localhost:4000/v1
#   Any OpenAI-compatible API
# AI_FILTER_BASE_URL=http://localhost:11434/v1

# Optional: second model for ensemble consensus
# When set, both models estimate probability and results are
# combined via confidence-weighted averaging for more robust decisions
# AI_FILTER_SECOND_MODEL=claude-sonnet-4-20250514

# Minimum AI confidence to approve trade (0.0-1.0)
# Higher = more selective, fewer trades copied
AI_FILTER_MIN_CONFIDENCE=0.6

# Minimum probability edge over market price to approve (0.0-1.0)
# e.g. 0.05 means AI must think true probability is 5%+ different from market
AI_FILTER_MIN_EDGE=0.05

# Cache analysis results for N minutes (avoids re-analyzing same market)
AI_FILTER_CACHE_MINUTES=15

# Max LLM API calls per minute (rate limiting)
AI_FILTER_MAX_CALLS_PER_MIN=10

# Timeout for LLM API calls in seconds
AI_FILTER_TIMEOUT_SECONDS=30

# If true, approve trades when AI filter errors (fail-open)
# If false, reject trades when AI filter errors (fail-closed)
AI_FILTER_FAIL_OPEN=true

# ==============================================
# PROXY (Optional — for networks that block Polymarket)
# ==============================================
# Route all API traffic through a proxy to bypass ISP/network filtering.
# Useful in countries where Polymarket is blocked (e.g. Portugal, France).
# Supports: HTTP, HTTPS, SOCKS5
# Examples:
#   SOCKS5:   socks5://127.0.0.1:1080
#   HTTP:     http://proxy.example.com:8080
#   HTTPS:    https://proxy.example.com:8080
# PROXY_URL=socks5://127.0.0.1:1080

# ==============================================
# ON-CHAIN MONITORING (Optional)
# ==============================================
# WebSocket RPC URL for monitoring on-chain trade settlements on Polygon
# Used for verification (not speed — CLOB WebSocket is faster)
# Get a free key at https://www.alchemy.com/ or https://www.infura.io/
# WS_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ==============================================
# FINFEEDAPI (Optional — paid, cross-platform data)
# ==============================================
# Provides unified market data from Polymarket, Kalshi, Manifold, and Myriad.
# Requires a paid API key from https://www.finfeedapi.com/
# FINFEED_API_KEY=your-finfeed-api-key

# ==============================================
# BULLEPEN.FI INTEGRATION (Optional)
# ==============================================
# Enables smart money discovery, market data enrichment, and CLI execution fallback
# Requires: npm install -g @bullpenfi/cli && bullpen login
# Enable experimental features: bullpen experimental enable prediction_analytics
BULLPEN_ENABLED=false

# ==============================================
# MARKET INTELLIGENCE (Optional)
# ==============================================
# Monitor RSS/news feeds for market-moving events, classify sentiment,
# and generate alerts correlated to active Polymarket markets
INTELLIGENCE_ENABLED=false

# Comma-separated custom RSS feed URLs (leave empty for defaults: BBC, NYT, Reuters, CoinTelegraph, CoinDesk)
# INTELLIGENCE_RSS_FEEDS=https://example.com/rss,https://other.com/feed

# How often to poll feeds in milliseconds (default: 300000 = 5 min)
INTELLIGENCE_POLL_INTERVAL=300000

# Minimum impact score (0-100) to trigger an alert (default: 50)
INTELLIGENCE_ALERT_THRESHOLD=0.5

# Comma-separated categories to monitor (empty = all)
# Options: political, economic, sports, crypto, regulatory, technology, geopolitical, social, weather, entertainment
# INTELLIGENCE_CATEGORIES=crypto,political,economic

# Comma-separated keywords to boost impact score for (e.g. your active markets)
# INTELLIGENCE_WATCH_KEYWORDS=bitcoin,election,trump,fed

# Enable LLM-powered sentiment analysis (uses AI_FILTER_API_KEY by default)
INTELLIGENCE_USE_LLM=false

# Override LLM API key for intelligence (defaults to AI_FILTER_API_KEY)
# INTELLIGENCE_LLM_API_KEY=sk-...

# Export events on exit
INTELLIGENCE_EXPORT=false

# ==============================================
# TELEGRAM NOTIFICATIONS (Optional)
# ==============================================
# Get a bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Send /start to @userinfobot to get your chat ID
# TELEGRAM_CHAT_ID=123456789

# ==============================================
# DRY RUN MODE
# ==============================================
# true = simulation only (no real orders placed)
# false = live trading with real money
DRY_RUN=true

# ==============================================
# PAPER TRADING MODE (Optional)
# ==============================================
# Simulate trades with virtual money — no real orders, full journal + metrics
# Compatible with all other features (AI filter, risk management, Telegram)
PAPER_TRADING=false

# Starting virtual capital in USDC
PAPER_STARTING_CAPITAL=1000

# Fill simulation mode: target_price | market_price
# target_price = fill at the same price the target traded at
# market_price = fill at market mid price
PAPER_FILL_MODE=target_price

# Simulated slippage in basis points (30 = 0.3%)
PAPER_SLIPPAGE_BPS=30

# Simulated gas cost per trade in USDC
PAPER_GAS_COST=0.01

# Auto-close positions when markets resolve
PAPER_AUTO_CLOSE=true

# Export trade journal on exit
PAPER_EXPORT_ON_EXIT=true

# Export format: json | csv
PAPER_EXPORT_FORMAT=json

# ==============================================
# BACKTEST MODE (Optional)
# ==============================================
# Replay historical trades through the paper trading engine
# Fetches from Polymarket Data API and runs strategy offline
# Does NOT need CLOB client or real wallet — just TARGET_WALLETS
BACKTEST=false

# Time range for backtest (ISO dates or epoch milliseconds)
BACKTEST_START=2025-01-01
BACKTEST_END=2025-06-01

# Starting virtual capital
BACKTEST_STARTING_CAPITAL=1000

# Speed multiplier for replay (100 = 100x faster than realtime)
BACKTEST_SPEED=100

# Simulated slippage in basis points
BACKTEST_SLIPPAGE_BPS=30

# Simulated gas cost per trade
BACKTEST_GAS_COST=0.01

# Export results on completion
BACKTEST_EXPORT=true

# Export format: json | csv
BACKTEST_EXPORT_FORMAT=json
